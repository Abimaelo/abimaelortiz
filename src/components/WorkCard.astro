---
interface Props {
  title: string;
  serie: string;
  year: number | string;
  technique?: string;
  dimensions?: string;
  image: string;
  href: string;
}

const { title, serie, year, technique, dimensions, image, href } = Astro.props;
---

<a href={href} class="group block overflow-hidden">
  <!-- Imagen -->
  <div class="relative overflow-hidden bg-[#1a1a1a] aspect-[4/5]">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <!-- Overlay sutil al hover -->
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-500"></div>
  </div>

  <!-- Metadatos -->
  <div class="pt-4 pb-2">
    <p
      class="text-[10px] tracking-[0.25em] uppercase text-[#c8a96e] mb-1"
      style="font-family: 'Inter', sans-serif;"
    >
      {serie} &nbsp;·&nbsp; {year}
    </p>
    <h3
      class="font-serif text-base text-[#f5f5f0] group-hover:text-[#c8a96e] transition-colors duration-300"
      style="font-family: 'Playfair Display', serif;"
    >
      {title}
    </h3>
    {technique && (
      <p class="text-xs text-[#888888] mt-1" style="font-family: 'Inter', sans-serif;">
        {technique}{dimensions ? ` — ${dimensions}` : ''}
      </p>
    )}
  </div>
</a>
