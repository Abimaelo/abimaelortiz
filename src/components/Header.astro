---
const navLinks = [
  { href: '/obras', label: 'Obras' },
  { href: '/textos', label: 'Textos' },
  { href: '/bio', label: 'Biografía' },
  { href: '/exposiciones', label: 'Exposiciones' },
  { href: '/contacto', label: 'Contacto' },
  { href: '/tienda', label: 'Tienda' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 py-5"
  style="background: linear-gradient(to bottom, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0) 100%);"
>
  <!-- Logo / Nombre -->
  <a
    href="/"
    class="font-serif text-lg tracking-widest uppercase text-[#f5f5f0] hover:text-[#c8a96e] transition-colors duration-300"
    style="font-family: 'Playfair Display', serif; letter-spacing: 0.15em;"
  >
    Abimael Ortiz
  </a>

  <!-- Navegación desktop -->
  <nav class="hidden md:flex items-center gap-8">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'text-xs tracking-[0.2em] uppercase transition-colors duration-300',
          currentPath.startsWith(href)
            ? 'text-[#c8a96e]'
            : 'text-[#888888] hover:text-[#f5f5f0]',
        ]}
        style="font-family: 'Inter', sans-serif; font-weight: 400;"
      >
        {label}
      </a>
    ))}
  </nav>

  <!-- Toggle de tema -->
  <button
    id="theme-toggle"
    class="flex items-center justify-center w-8 h-8 text-[#888888] hover:text-[#f5f5f0] transition-colors duration-300"
    aria-label="Cambiar tema"
    title="Modo claro / oscuro"
  >
    <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>

  <!-- Menú móvil (botón) -->
  <button
    id="menu-toggle"
    class="md:hidden flex flex-col gap-1.5 p-1"
    aria-label="Abrir menú"
  >
    <span class="block w-6 h-px bg-[#f5f5f0] transition-all duration-300" id="line1"></span>
    <span class="block w-6 h-px bg-[#f5f5f0] transition-all duration-300" id="line2"></span>
    <span class="block w-4 h-px bg-[#f5f5f0] transition-all duration-300" id="line3"></span>
  </button>
</header>

<!-- Menú móvil (panel) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-[#0a0a0a] flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-400"
>
  <a
    href="/"
    class="font-serif text-2xl text-[#f5f5f0] hover:text-[#c8a96e] transition-colors"
    style="font-family: 'Playfair Display', serif;"
  >
    Abimael Ortiz
  </a>
  <div class="w-px h-8 bg-[#2a2a2a]"></div>
  {navLinks.map(({ href, label }) => (
    <a
      href={href}
      class="text-sm tracking-[0.3em] uppercase text-[#888888] hover:text-[#f5f5f0] transition-colors duration-300"
      style="font-family: 'Inter', sans-serif;"
    >
      {label}
    </a>
  ))}
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const line3 = document.getElementById('line3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (open) {
      menu!.classList.remove('opacity-0', 'pointer-events-none');
      menu!.classList.add('opacity-100');
      line3!.classList.add('w-6');
    } else {
      menu!.classList.add('opacity-0', 'pointer-events-none');
      menu!.classList.remove('opacity-100');
      line3!.classList.remove('w-6');
    }
  });

  // Cerrar al hacer clic en un enlace
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100');
    });
  });

  // ---- Theme toggle ----
  const themeToggle = document.getElementById('theme-toggle');
  const iconSun  = document.getElementById('icon-sun')  as HTMLElement | null;
  const iconMoon = document.getElementById('icon-moon') as HTMLElement | null;

  function syncThemeIcon() {
    const isLight = document.documentElement.classList.contains('light');
    if (iconSun)  iconSun.style.display  = isLight ? 'none'  : 'block';
    if (iconMoon) iconMoon.style.display = isLight ? 'block' : 'none';
  }

  syncThemeIcon();

  themeToggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('light');
    const isLight = document.documentElement.classList.contains('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    syncThemeIcon();
  });
</script>
