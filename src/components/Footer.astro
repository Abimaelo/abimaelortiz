---
const year = new Date().getFullYear();

const socialLinks = [
  { href: 'https://instagram.com/abimaelortiz', label: 'Instagram', icon: 'IG' },
  { href: 'https://facebook.com/abimaelortiz.art', label: 'Facebook', icon: 'FB' },
];
---

<footer class="border-t border-[#1a1a1a] mt-24 px-6 md:px-12 py-12">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">

    <!-- Nombre y copyright -->
    <div class="text-center md:text-left">
      <p
        class="font-serif text-base text-[#f5f5f0] mb-1"
        style="font-family: 'Playfair Display', serif;"
      >
        Abimael Ortiz Álvarez
      </p>
      <p class="text-xs text-[#888888] tracking-wider" style="font-family: 'Inter', sans-serif;">
        Artista Visual &nbsp;·&nbsp; © {year}
      </p>
    </div>

    <!-- Navegación rápida -->
    <nav class="flex items-center gap-6">
      <a href="/obras" class="text-xs text-[#888888] hover:text-[#f5f5f0] tracking-widest uppercase transition-colors" style="font-family: 'Inter', sans-serif;">Obras</a>
      <a href="/bio" class="text-xs text-[#888888] hover:text-[#f5f5f0] tracking-widest uppercase transition-colors" style="font-family: 'Inter', sans-serif;">Bio</a>
      <a href="/contacto" class="text-xs text-[#888888] hover:text-[#f5f5f0] tracking-widest uppercase transition-colors" style="font-family: 'Inter', sans-serif;">Contacto</a>
    </nav>

    <!-- Redes sociales -->
    <div class="flex items-center gap-4">
      {socialLinks.map(({ href, label, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          class="w-8 h-8 flex items-center justify-center border border-[#2a2a2a] text-[#888888] hover:border-[#c8a96e] hover:text-[#c8a96e] transition-colors duration-300 text-[10px] tracking-wider"
          style="font-family: 'Inter', sans-serif;"
        >
          {icon}
        </a>
      ))}
    </div>

  </div>
</footer>
