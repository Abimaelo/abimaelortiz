---
import Layout from '../../layouts/Layout.astro';

const estudios = [
  { num: 'I',   image: '/images/estudio-01.jpg', orientacion: 'vertical'   },
  { num: 'II',  image: '/images/estudio-02.jpg', orientacion: 'vertical'   },
  { num: 'III', image: '/images/estudio-03.jpg', orientacion: 'vertical'   },
  { num: 'IV',  image: '/images/estudio-04.jpg', orientacion: 'vertical'   },
  { num: 'V',   image: '/images/estudio-05.jpg', orientacion: 'horizontal' },
];

const meta = {
  serie: 'Estudios',
  year: 2025,
  technique: 'Medio mixto sobre papel',
  dimensions: '9 × 12 in',
};
---

<Layout title="Obras" description="Galería de obras de Abimael Ortiz Álvarez.">

  <!-- Encabezado -->
  <div class="pt-32 pb-16 px-6 md:px-12 border-b border-[#1a1a1a]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4"
         style="font-family:'Inter',sans-serif;">Portafolio</p>
      <h1 class="font-serif text-4xl md:text-6xl text-[#f5f5f0]"
          style="font-family:'Playfair Display',serif;">Obras</h1>
    </div>
  </div>

  <!-- Etiqueta de serie -->
  <div class="px-6 md:px-12 py-6 border-b border-[#1a1a1a]">
    <div class="max-w-6xl mx-auto flex flex-wrap items-baseline gap-3 md:gap-6">
      <h2 class="font-serif text-lg text-[#f5f5f0]"
          style="font-family:'Playfair Display',serif;">{meta.serie}</h2>
      <span class="text-[#2a2a2a]">·</span>
      <span class="text-[10px] tracking-[0.25em] uppercase text-[#888888]"
            style="font-family:'Inter',sans-serif;">{meta.technique}</span>
      <span class="text-[#2a2a2a]">·</span>
      <span class="text-[10px] tracking-[0.25em] uppercase text-[#888888]"
            style="font-family:'Inter',sans-serif;">{meta.dimensions}</span>
      <span class="text-[#2a2a2a]">·</span>
      <span class="text-[10px] tracking-[0.25em] uppercase text-[#888888]"
            style="font-family:'Inter',sans-serif;">{meta.year}</span>
    </div>
  </div>

  <!-- Galería -->
  <section class="px-6 md:px-12 py-16">
    <div class="max-w-6xl mx-auto">

      <!-- 4 verticales -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5 mb-4 md:mb-5">
        {estudios.filter(e => e.orientacion === 'vertical').map((obra, i) => (
          <button
            class="group overflow-hidden bg-[#111] text-left cursor-zoom-in"
            data-lightbox={i}
            aria-label={`Abrir Sin título ${obra.num}`}
          >
            <div class="relative overflow-hidden aspect-[3/4]">
              <img
                src={obra.image}
                alt={`Sin título ${obra.num}`}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="pt-3 pb-1 px-1">
              <p class="text-[10px] tracking-[0.2em] uppercase text-[#888888]"
                 style="font-family:'Inter',sans-serif;">Sin título {obra.num}</p>
            </div>
          </button>
        ))}
      </div>

      <!-- Horizontal -->
      {estudios.filter(e => e.orientacion === 'horizontal').map((obra, i) => (
        <button
          class="group overflow-hidden bg-[#111] text-left w-full cursor-zoom-in"
          data-lightbox={4}
          aria-label={`Abrir Sin título ${obra.num}`}
        >
          <div class="relative overflow-hidden aspect-[4/3] md:aspect-[16/9]">
            <img
              src={obra.image}
              alt={`Sin título ${obra.num}`}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="pt-3 pb-1 px-1">
            <p class="text-[10px] tracking-[0.2em] uppercase text-[#888888]"
               style="font-family:'Inter',sans-serif;">Sin título {obra.num}</p>
          </div>
        </button>
      ))}

    </div>
  </section>

</Layout>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-[100] bg-black/95 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-label="Visor de obra"
>
  <!-- Cerrar al hacer clic en el fondo -->
  <div id="lb-backdrop" class="absolute inset-0"></div>

  <!-- Imagen -->
  <div class="relative z-10 flex items-center justify-center w-full h-full p-4 md:p-12">
    <img
      id="lb-img"
      src=""
      alt=""
      class="max-w-full max-h-full object-contain select-none"
      style="max-height: calc(100vh - 120px);"
    />
  </div>

  <!-- Metadatos -->
  <div class="absolute bottom-0 left-0 right-0 z-10 flex items-end justify-between px-6 md:px-12 py-6">
    <div>
      <p id="lb-title" class="font-serif text-base text-[#f5f5f0]"
         style="font-family:'Playfair Display',serif;"></p>
      <p class="text-[10px] tracking-[0.2em] uppercase text-[#888888] mt-1"
         style="font-family:'Inter',sans-serif;">
        Medio mixto sobre papel · 9 × 12 in · 2025
      </p>
    </div>
    <p id="lb-counter" class="text-[10px] tracking-[0.3em] text-[#888888]"
       style="font-family:'Inter',sans-serif;"></p>
  </div>

  <!-- Botón cerrar -->
  <button
    id="lb-close"
    class="absolute top-5 right-6 z-20 text-[#888888] hover:text-[#f5f5f0] transition-colors text-xs tracking-[0.3em] uppercase"
    style="font-family:'Inter',sans-serif;"
    aria-label="Cerrar"
  >
    Cerrar ✕
  </button>

  <!-- Anterior -->
  <button
    id="lb-prev"
    class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center text-[#888888] hover:text-[#f5f5f0] transition-colors border border-[#2a2a2a] hover:border-[#f5f5f0]"
    aria-label="Obra anterior"
  >
    ←
  </button>

  <!-- Siguiente -->
  <button
    id="lb-next"
    class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center text-[#888888] hover:text-[#f5f5f0] transition-colors border border-[#2a2a2a] hover:border-[#f5f5f0]"
    aria-label="Obra siguiente"
  >
    →
  </button>
</div>

<script>
  const obras = [
    { src: '/images/estudio-01.jpg', title: 'Sin título I' },
    { src: '/images/estudio-02.jpg', title: 'Sin título II' },
    { src: '/images/estudio-03.jpg', title: 'Sin título III' },
    { src: '/images/estudio-04.jpg', title: 'Sin título IV' },
    { src: '/images/estudio-05.jpg', title: 'Sin título V' },
  ];

  let current = 0;

  const lb       = document.getElementById('lightbox')!;
  const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
  const lbTitle  = document.getElementById('lb-title')!;
  const lbCount  = document.getElementById('lb-counter')!;
  const lbClose  = document.getElementById('lb-close')!;
  const lbPrev   = document.getElementById('lb-prev')!;
  const lbNext   = document.getElementById('lb-next')!;
  const lbBack   = document.getElementById('lb-backdrop')!;

  function show(index: number) {
    current = (index + obras.length) % obras.length;
    const obra = obras[current];
    lbImg.src  = obra.src;
    lbImg.alt  = obra.title;
    lbTitle.textContent  = obra.title;
    lbCount.textContent  = `${current + 1} / ${obras.length}`;
  }

  function open(index: number) {
    show(index);
    lb.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lb.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  // Abrir desde la galería
  document.querySelectorAll<HTMLButtonElement>('[data-lightbox]').forEach((btn) => {
    btn.addEventListener('click', () => open(Number(btn.dataset.lightbox)));
  });

  // Controles
  lbClose.addEventListener('click', close);
  lbBack.addEventListener('click', close);
  lbPrev.addEventListener('click', () => show(current - 1));
  lbNext.addEventListener('click', () => show(current + 1));

  // Teclado
  document.addEventListener('keydown', (e) => {
    if (lb.classList.contains('pointer-events-none')) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowLeft')   show(current - 1);
    if (e.key === 'ArrowRight')  show(current + 1);
  });
</script>
