---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Exposiciones"
  description="Trayectoria expositiva de Abimael Ortiz Álvarez — Artista visual puertorriqueño."
>

  <div class="pt-32 pb-16 px-6 md:px-12 border-b border-[#1a1a1a]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4" style="font-family:'Inter',sans-serif;">Currículum</p>
      <h1 class="font-serif text-4xl md:text-6xl text-[#f5f5f0]" style="font-family:'Playfair Display',serif;">Exposiciones</h1>
    </div>
  </div>

  <div class="px-6 md:px-12 py-20">
    <div class="max-w-4xl mx-auto space-y-20">

      <!-- Formación -->
      <section>
        <h2
          class="font-serif text-2xl text-[#f5f5f0] mb-8 pb-4 border-b border-[#1a1a1a]"
          style="font-family:'Playfair Display',serif;"
        >
          Formación
        </h2>
        <div class="border-t border-[#1a1a1a] pt-0 divide-y divide-[#1a1a1a]">
          <div class="flex items-start gap-8 py-5">
            <span class="text-xs text-[#888888] pt-0.5 w-24 flex-shrink-0" style="font-family:'Inter',sans-serif;">1997 — 2002</span>
            <div>
              <p class="font-serif text-base text-[#f5f5f0]" style="font-family:'Playfair Display',serif;">
                Escuela de Artes Plásticas
              </p>
              <p class="text-xs text-[#888888] mt-1" style="font-family:'Inter',sans-serif;">San Juan, Puerto Rico</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Exposiciones individuales -->
      <section>
        <h2
          class="font-serif text-2xl text-[#f5f5f0] mb-8 pb-4 border-b border-[#1a1a1a]"
          style="font-family:'Playfair Display',serif;"
        >
          Exposiciones individuales
        </h2>
        <div class="py-10 text-center">
          <p class="text-xs tracking-[0.3em] uppercase text-[#2a2a2a]" style="font-family:'Inter',sans-serif;">
            En desarrollo — próximamente
          </p>
        </div>
      </section>

      <!-- Exposiciones colectivas -->
      <section>
        <h2
          class="font-serif text-2xl text-[#f5f5f0] mb-8 pb-4 border-b border-[#1a1a1a]"
          style="font-family:'Playfair Display',serif;"
        >
          Exposiciones colectivas
        </h2>
        <div class="py-10 text-center">
          <p class="text-xs tracking-[0.3em] uppercase text-[#2a2a2a]" style="font-family:'Inter',sans-serif;">
            En desarrollo — próximamente
          </p>
        </div>
      </section>

      <!-- Nota -->
      <div class="border border-[#1a1a1a] p-8">
        <p
          class="font-serif text-base text-[#888888] leading-relaxed italic"
          style="font-family:'Playfair Display',serif;"
        >
          "Hoy doy mis primeros pasos en el mundo del arte. Esta página crecerá con la práctica."
        </p>
        <div class="mt-6">
          <a
            href="/contacto"
            class="text-xs tracking-[0.3em] uppercase text-[#888888] hover:text-[#f5f5f0] transition-colors border-b border-[#2a2a2a] hover:border-[#f5f5f0] pb-0.5"
            style="font-family:'Inter',sans-serif;"
          >
            Contactar al artista
          </a>
        </div>
      </div>

    </div>
  </div>

</Layout>
