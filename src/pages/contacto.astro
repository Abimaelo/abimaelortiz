---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto"
  description="Contacta con Abimael Ortiz Álvarez — Consultas, prensa y colaboraciones."
>

  <div class="pt-32 pb-16 px-6 md:px-12 border-b border-[#1a1a1a]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4" style="font-family:'Inter',sans-serif;">Contacto</p>
      <h1 class="font-serif text-4xl md:text-6xl text-[#f5f5f0]" style="font-family:'Playfair Display',serif;">Hablemos</h1>
    </div>
  </div>

  <div class="px-6 md:px-12 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-[1fr_1.5fr] gap-16">

      <!-- Info de contacto -->
      <div class="space-y-10">
        <div>
          <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4" style="font-family:'Inter',sans-serif;">Correo</p>
          <a
            href="mailto:mail@abimaelortiz.com"
            class="font-serif text-lg text-[#f5f5f0] hover:text-[#c8a96e] transition-colors"
            style="font-family:'Playfair Display',serif;"
          >
            mail@abimaelortiz.com
          </a>
        </div>

        <div class="border-t border-[#1a1a1a] pt-8">
          <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4" style="font-family:'Inter',sans-serif;">Redes sociales</p>
          <div class="space-y-3">
            <a
              href="https://instagram.com/abimaelortiz"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-sm text-[#888888] hover:text-[#f5f5f0] transition-colors"
              style="font-family:'Inter',sans-serif;"
            >
              <span class="text-[10px] tracking-widest uppercase w-8">IG</span>
              @abimaelortiz
            </a>
            <a
              href="https://facebook.com/abimaelortiz.art"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-sm text-[#888888] hover:text-[#f5f5f0] transition-colors"
              style="font-family:'Inter',sans-serif;"
            >
              <span class="text-[10px] tracking-widest uppercase w-8">FB</span>
              abimaelortiz.art
            </a>
          </div>
        </div>

        <div class="border-t border-[#1a1a1a] pt-8">
          <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-3" style="font-family:'Inter',sans-serif;">Consultas</p>
          <p class="text-sm text-[#888888] leading-relaxed" style="font-family:'Inter',sans-serif; font-weight:300;">
            Para adquisición de obra, prensa, colaboraciones institucionales o cualquier otra consulta, no dudes en escribir.
          </p>
        </div>
      </div>

      <!-- Formulario -->
      <form
        name="contacto"
        method="POST"
        data-netlify="true"
        class="space-y-6"
      >
        <input type="hidden" name="form-name" value="contacto" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label
              for="nombre"
              class="block text-[10px] tracking-[0.3em] uppercase text-[#888888] mb-2"
              style="font-family:'Inter',sans-serif;"
            >
              Nombre
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              class="w-full bg-transparent border border-[#2a2a2a] px-4 py-3 text-sm text-[#f5f5f0] placeholder-[#3a3a3a] focus:outline-none focus:border-[#c8a96e] transition-colors"
              style="font-family:'Inter',sans-serif;"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label
              for="email"
              class="block text-[10px] tracking-[0.3em] uppercase text-[#888888] mb-2"
              style="font-family:'Inter',sans-serif;"
            >
              Correo electrónico
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-transparent border border-[#2a2a2a] px-4 py-3 text-sm text-[#f5f5f0] placeholder-[#3a3a3a] focus:outline-none focus:border-[#c8a96e] transition-colors"
              style="font-family:'Inter',sans-serif;"
              placeholder="tu@correo.com"
            />
          </div>
        </div>

        <div>
          <label
            for="asunto"
            class="block text-[10px] tracking-[0.3em] uppercase text-[#888888] mb-2"
            style="font-family:'Inter',sans-serif;"
          >
            Asunto
          </label>
          <select
            id="asunto"
            name="asunto"
            class="w-full bg-[#0a0a0a] border border-[#2a2a2a] px-4 py-3 text-sm text-[#888888] focus:outline-none focus:border-[#c8a96e] transition-colors"
            style="font-family:'Inter',sans-serif;"
          >
            <option value="">Selecciona un asunto</option>
            <option value="adquisicion">Adquisición de obra</option>
            <option value="prensa">Prensa / medios</option>
            <option value="colaboracion">Colaboración institucional</option>
            <option value="otro">Otro</option>
          </select>
        </div>

        <div>
          <label
            for="mensaje"
            class="block text-[10px] tracking-[0.3em] uppercase text-[#888888] mb-2"
            style="font-family:'Inter',sans-serif;"
          >
            Mensaje
          </label>
          <textarea
            id="mensaje"
            name="mensaje"
            required
            rows="6"
            class="w-full bg-transparent border border-[#2a2a2a] px-4 py-3 text-sm text-[#f5f5f0] placeholder-[#3a3a3a] focus:outline-none focus:border-[#c8a96e] transition-colors resize-none"
            style="font-family:'Inter',sans-serif;"
            placeholder="Escribe tu mensaje aquí..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-4 border border-[#f5f5f0] text-[#f5f5f0] text-xs tracking-[0.3em] uppercase hover:bg-[#f5f5f0] hover:text-[#0a0a0a] transition-all duration-300"
          style="font-family:'Inter',sans-serif;"
        >
          Enviar mensaje
        </button>
      </form>

    </div>
  </div>

</Layout>
