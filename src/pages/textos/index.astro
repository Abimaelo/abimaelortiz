---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const textos = (await getCollection('textos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title="Textos"
  description="Escritos de Abimael Ortiz Álvarez sobre su práctica artística y proceso creativo."
>

  <div class="pt-32 pb-16 px-6 md:px-12 border-b border-[#1a1a1a]">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8 items-end">
      <div>
        <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4" style="font-family:'Inter',sans-serif;">Escritura</p>
        <h1 class="font-serif text-4xl md:text-6xl text-[#f5f5f0]" style="font-family:'Playfair Display',serif;">Textos</h1>
      </div>
      <p class="text-sm text-[#888888] leading-relaxed max-w-sm" style="font-family:'Inter',sans-serif; font-weight:300;">
        Escritos sobre práctica artística, proceso y las ideas que alimentan la obra.
      </p>
    </div>
  </div>

  <section class="px-6 md:px-12 py-16">
    <div class="max-w-4xl mx-auto">

      {textos.length === 0 ? (
        <div class="py-20 text-center">
          <p class="text-xs tracking-[0.3em] uppercase text-[#2a2a2a]" style="font-family:'Inter',sans-serif;">
            Próximamente
          </p>
        </div>
      ) : (
        <div class="divide-y divide-[#1a1a1a]">
          {textos.map((texto) => (
            <a
              href={`/textos/${texto.id}`}
              class="group flex flex-col md:flex-row md:items-baseline gap-2 md:gap-12 py-8 hover:bg-[#0f0f0f] -mx-6 px-6 transition-colors duration-200"
            >
              <span
                class="text-[10px] tracking-[0.2em] text-[#888888] flex-shrink-0 md:w-24"
                style="font-family:'Inter',sans-serif;"
              >
                {texto.data.date.toLocaleDateString('es', { year: 'numeric', month: 'long' })}
              </span>
              <div class="flex-1">
                <h2
                  class="font-serif text-xl md:text-2xl text-[#f5f5f0] group-hover:text-[#c8a96e] transition-colors duration-300 mb-2"
                  style="font-family:'Playfair Display',serif;"
                >
                  {texto.data.title}
                </h2>
                {texto.data.description && (
                  <p class="text-sm text-[#888888] leading-relaxed" style="font-family:'Inter',sans-serif; font-weight:300;">
                    {texto.data.description}
                  </p>
                )}
              </div>
              <span class="text-[#2a2a2a] group-hover:text-[#888888] transition-colors text-lg flex-shrink-0 hidden md:block">
                →
              </span>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

</Layout>
