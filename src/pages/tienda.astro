---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tienda"
  description="Tienda de obra original y ediciones limitadas de Abimael Ortiz Álvarez."
>

  <div class="pt-32 pb-16 px-6 md:px-12 border-b border-[#1a1a1a]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e] mb-4" style="font-family:'Inter',sans-serif;">Adquisición</p>
      <h1 class="font-serif text-4xl md:text-6xl text-[#f5f5f0]" style="font-family:'Playfair Display',serif;">Tienda</h1>
    </div>
  </div>

  <!-- Próximamente -->
  <div class="px-6 md:px-12 py-32 flex items-center justify-center">
    <div class="max-w-md text-center space-y-6">

      <!-- Ícono decorativo -->
      <div class="w-16 h-16 border border-[#2a2a2a] mx-auto flex items-center justify-center">
        <div class="w-6 h-6 border border-[#c8a96e]"></div>
      </div>

      <p class="text-[10px] tracking-[0.4em] uppercase text-[#c8a96e]" style="font-family:'Inter',sans-serif;">Próximamente</p>

      <h2
        class="font-serif text-2xl md:text-3xl text-[#f5f5f0]"
        style="font-family:'Playfair Display',serif;"
      >
        Obra original y ediciones limitadas
      </h2>

      <p
        class="text-sm text-[#888888] leading-relaxed"
        style="font-family:'Inter',sans-serif; font-weight:300;"
      >
        Esta sección estará disponible pronto. Para consultar disponibilidad y precios de obras originales, contacta directamente.
      </p>

      <a
        href="/contacto"
        class="inline-block px-8 py-3 border border-[#f5f5f0] text-[#f5f5f0] text-xs tracking-[0.3em] uppercase hover:bg-[#f5f5f0] hover:text-[#0a0a0a] transition-all duration-300"
        style="font-family:'Inter',sans-serif;"
      >
        Consultar disponibilidad
      </a>

    </div>
  </div>

</Layout>
